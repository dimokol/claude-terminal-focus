{
  "name": "claude-notifications",
  "displayName": "Claude Notifications",
  "description": "All-in-one Claude Code notifications — sound alerts, OS notifications, and terminal focus. One-click setup, zero external dependencies.",
  "version": "2.0.0",
  "publisher": "dimokol",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dimokol/claude-notifications"
  },
  "bugs": {
    "url": "https://github.com/dimokol/claude-notifications/issues"
  },
  "homepage": "https://github.com/dimokol/claude-notifications#readme",
  "icon": "images/icon.png",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "claude",
    "claude-code",
    "claude-cli",
    "terminal",
    "focus",
    "notification",
    "notifications",
    "anthropic",
    "ai",
    "productivity",
    "sound",
    "alert",
    "toast",
    "ai-coding",
    "developer-tools"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./extension.js",
  "dependencies": {
    "node-notifier": "^10.0.1"
  },
  "contributes": {
    "commands": [
      {
        "command": "claudeNotifications.setupHooks",
        "title": "Claude Notifications: Set Up Claude Code Hooks"
      },
      {
        "command": "claudeNotifications.removeHooks",
        "title": "Claude Notifications: Remove Claude Code Hooks"
      },
      {
        "command": "claudeNotifications.setupGitignore",
        "title": "Claude Notifications: Add Signal Files to Global Gitignore"
      },
      {
        "command": "claudeNotifications.testNotification",
        "title": "Claude Notifications: Test Notification"
      }
    ],
    "configuration": {
      "title": "Claude Notifications",
      "properties": {
        "claudeNotifications.sound.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Play a sound when Claude needs attention"
        },
        "claudeNotifications.sound.volume": {
          "type": "number",
          "default": 0.5,
          "minimum": 0,
          "maximum": 1,
          "description": "Sound volume (0.0 to 1.0, macOS/Linux only)"
        },
        "claudeNotifications.notification.useFallback": {
          "type": "boolean",
          "default": true,
          "description": "Use OS-native notifications (via node-notifier) as fallback when VS Code window is focused. Respects OS notification preferences — never bypasses DND or mute."
        },
        "claudeNotifications.autoSetupHooks": {
          "type": "boolean",
          "default": true,
          "description": "Prompt to install Claude Code hooks on first activation"
        }
      }
    }
  }
}
